{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>AlaudaDevops/renovate-config:base"
  ],
  "baseBranches": [
    "/^alauda-1.*/"
  ],
  "postUpdateOptions": [
    "gomodTidy"
  ],
  "assignees": [
    "chengjingtao",
    "yuzichen12123"
  ],
  "ignorePaths": [
    "subtree/**/*Dockerfile*",
    "testing/**/*Containerfile*"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "datasourceTemplate": "golang-version",
      "managerFilePatterns": [
        "/^subtree\\/harbor\\/make\\/patches\\/patch-amd64\\.sh$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-zA-Z0-9-._]+?) depName=(?<depName>[^\\s]+?)(?: (lookupName|packageName)=(?<packageName>[^\\s]+?))?(?: versioning=(?<versioning>[^\\s]+?))?(?: extractVersion=(?<extractVersion>[^\\s]+?))?(?: registryUrl=(?<registryUrl>[^\\s]+?))?\\s(?:export)\\s+[A-Za-z0-9_]+?_VERSION[ =][\"']?(?<currentValue>.+?)[\"']?\\s"
      ],
      "description": "Update golang image in `patch-amd64.sh`."
    }
  ]
}
